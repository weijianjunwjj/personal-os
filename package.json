{
  "name": "personal-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "add:diary": "tsx scripts/add-diary.ts",
    "os:run": "tsx scripts/os-daemon.ts --run",
    "os:watch": "tsx scripts/os-daemon.ts --watch",
    "daemon:start": "tsx scripts/os-daemon.ts --watch",
    "daemon:install": "powershell -ExecutionPolicy Bypass -File scripts/install-windows-daemon.ps1",
    "daemon:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-windows-daemon.ps1",
    "jd:import": "tsx scripts/import-jd-screenshot.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}
